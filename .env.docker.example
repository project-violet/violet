# Copy to .env if you want to keep runtime data outside the checkout.
VIOLET_DATA_ROOT=./data

# Optional local overrides for the search datasets.
VIOLET_MESSAGE_SEARCH_DATA=./violet-message-search/data/merged-0.fscm
VIOLET_GRAPH_DATA=./violet-graph/graph.csv
VIOLET_RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B
VIOLET_VLLM_VERSION=v0.25.1
VIOLET_RERANKER_GPU_MEMORY_UTILIZATION=0.30
VIOLET_RERANKER_PORT=8082
VIOLET_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B-GGUF:Q5_K_M
VIOLET_LLAMA_CPP_VERSION=server-cuda-b10015
VIOLET_EMBEDDING_PORT=8081

# Run fast-hsync once at startup, then wait this many seconds after each run.
HSYNC_INTERVAL_SECONDS=3600
